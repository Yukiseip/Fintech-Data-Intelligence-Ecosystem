{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL-Fintech",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "description": "Real-time fraud alert monitoring by rule, country, and severity",
  "editable": true,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "postgres-fintech" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Open Alerts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-fintech" },
          "rawSql": "SELECT COUNT(*) AS value FROM gold.alerts_log WHERE status = 'open'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres-fintech" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Avg Severity Score",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-fintech" },
          "rawSql": "SELECT AVG(severity_score) AS value FROM gold.alerts_log WHERE alert_timestamp >= NOW() - INTERVAL '7 days'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres-fintech" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "title": "Alert Timeline by Rule (7d)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-fintech" },
          "rawSql": "SELECT DATE(alert_timestamp) AS time, reason_code AS metric, COUNT(*) AS value FROM gold.alerts_log WHERE alert_timestamp >= NOW() - INTERVAL '7 days' GROUP BY DATE(alert_timestamp), reason_code ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "postgres-fintech" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 4,
      "title": "Alerts by Country Code (30d)",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-fintech" },
          "rawSql": "SELECT fs.country_code, SUM(fs.alert_count) AS alerts FROM gold.mart_fraud_summary fs WHERE fs.alert_date >= NOW() - INTERVAL '30 days' GROUP BY fs.country_code ORDER BY alerts DESC LIMIT 10",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "2m",
  "schemaVersion": 38,
  "tags": ["fintech", "fraud", "monitoring"],
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "title": "Fintech Fraud Monitoring",
  "uid": "fintech-fraud-monitoring",
  "version": 1
}
